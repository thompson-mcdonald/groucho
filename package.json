{
  "name": "groucho",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "sdk:codegen": "npm run codegen -w @groucho/sdk",
    "sdk:build": "npm run build -w @groucho/sdk",
    "sdk:test": "npm run test -w @groucho/sdk",
    "example:groucho": "npm run dev -w next-groucho-example",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "npm run sdk:build && changeset publish"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.97.0",
    "motion": "^12.38.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
