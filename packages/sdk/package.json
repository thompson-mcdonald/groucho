{
  "name": "@groucho-gatekeeper/sdk",
  "version": "0.1.0",
  "description": "Headless client, server helper, and React UI for the Groucho gatekeeper API.",
  "license": "MIT",
  "homepage": "https://github.com/thompson-mcdonald/groucho/tree/main/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thompson-mcdonald/groucho.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/thompson-mcdonald/groucho/issues"
  },
  "keywords": [
    "groucho",
    "gatekeeper",
    "qualification",
    "doorman",
    "onboarding",
    "react",
    "react-component",
    "ai",
    "chat",
    "anthropic",
    "claude",
    "nextjs",
    "openapi",
    "typescript",
    "sdk"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "files": [
    "dist",
    "styles",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./groucho.css": "./styles/groucho.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "codegen": "openapi-typescript ../../docs/api/openapi.yaml -o src/generated/openapi.ts",
    "build": "pnpm run codegen && tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
